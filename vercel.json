{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "users.db",
          "index.html",
          "admin.html",
          "staff.html",
          "logo.png",
          "hero_image.png",
          "earnings_structure.jpg",
          "data_reward_flyer.jpg",
          "login_bg.jpg",
          "styles.css",
          "style1.css",
          "style2.css",
          "script.js",
          "admin.js"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
